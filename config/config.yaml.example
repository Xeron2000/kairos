# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    Kairos 交易分析系统配置                                   ║
# ║                    Kairos Trading Analysis Config                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
#
# 📖 使用说明 / Usage:
#    1. 复制此文件为 config.yaml / Copy this file to config.yaml
#    2. Kairos MCP server 使用 CCXT 公开 WebSocket 拉取数据，无需 API Key
#       Kairos MCP server uses CCXT public WebSocket — no API key required
#    3. 运行 `uv run kairos-mcp` 启动 MCP Server / Start MCP server
#
# ═══════════════════════════════════════════════════════════════════════════════

# 默认交易所 / Default Exchange
# ─────────────────────────────
# 可选值 / Options: "okx", "bybit", "binance"
exchange: "okx"

# 默认时间周期 / Default Timeframe
# ─────────────────────────────────
# 可选值 / Options: "1m", "5m", "15m", "1h", "1d"
defaultTimeframe: "1d"

# 时区 / Timezone
notificationTimezone: "Asia/Shanghai"

# ═══════════════════════════════════════════════════════════════════════════════
# Data Manager 配置 / Data Manager Configuration
# ═══════════════════════════════════════════════════════════════════════════════
dataManager:
  # 交易所列表 / Exchange list
  # 可选值 / Options: ["okx", "binance", "bybit"]
  exchanges:
    - "okx"
    - "binance"
    - "bybit"

  # 每个交易所订阅的 Top N 合约 / Top N symbols per exchange
  # Low volume = no opportunity. Top 30 keeps only liquid markets.
  topSymbols: 30

  # Symbol 刷新间隔 (小时) / Symbol refresh interval (hours)
  refreshIntervalHours: 4

  # 跨交易所信号去重窗口 (秒) / Cross-exchange dedup window (seconds)
  dedupWindowSeconds: 5

  # 同 symbol 最小推送间隔 (分钟) / Min interval between signals for same symbol
  # 避免同一币短时间内反复推送 / Prevents spam from same coin
  symbolCooldownMinutes: 30

# ═══════════════════════════════════════════════════════════════════════════════
# 价格异动探测器 / Price Velocity Detector
# ═══════════════════════════════════════════════════════════════════════════════
priceVelocity:
  enabled: true

  # 检测窗口 / Detection windows
  # seconds: 时间窗口 / Time window
  # threshold: 触发阈值 (%) / Trigger threshold (%)
  windows:
    - seconds: 30
      threshold: 0.5
    - seconds: 60
      threshold: 0.8
    - seconds: 120
      threshold: 1.2

  # 同 symbol+window 重复通知间隔 (秒) / Cooldown per symbol+window (seconds)
  cooldownSeconds: 60

# ═══════════════════════════════════════════════════════════════════════════════
# 成交量异动探测器 / Volume Spike Detector
# ═══════════════════════════════════════════════════════════════════════════════
volumeSpike:
  enabled: true

  # 触发倍数: 近期成交量 / 历史均量 / Trigger ratio: recent / baseline
  multiplier: 3.0

  # 对比窗口 (分钟) / Baseline window (minutes)
  windowMinutes: 10

  # 同 symbol 最小通知间隔 / Min interval between notifications per symbol
  # 支持格式 / Supported formats: "30s", "2m", "1h"
  minNotifyInterval: "2m"
